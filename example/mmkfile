# you could write this.
one for x in [ 1 2 3 4 ] {
    echo $x
}

two for y in [ a b c d ] {
    echo $y
}

downstream for x in [ 1 2 3 4 ] for y in [ a b c d ] : [one @ x=$x] [two @ y=$y] {
    echo $x $y
}


## but with groups, you can write it more succinctly, and don't need to duplicate lists of variables:


group numbers

g_one for x in [ 1 2 3 4 ] into numbers {
    echo $x
}

g_two for y in [ a b c d ] into numbers {
    echo $y
}

g_downstream : [numbers @ y ] {
    echo $x $y
}
